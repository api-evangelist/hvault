            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new orphan token that has no parent. Requires a root token or sudo capability."
        },
        {
          "info": {
            "name": "HashiCorp Vault Create token with role",
            "type": "http"
          },
          "http": {
            "method": "POST",
