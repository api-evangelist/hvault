            "method": "POST",
            "url": "https://vault.example.com/v1/auth/token/create",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new token. Certain options are only available when called by a root token. If used via the /auth/token/create/orphan endpoint, a root or sudo token is not required."
        },
        {
          "info": {
            "name": "HashiCorp Vault Create orphan token",
            "type": "http"
          },
          "http": {
            "method": "POST",
