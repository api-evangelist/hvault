                "description": "Name of the token role"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new token based on a named token role."
        },
        {
          "info": {
            "name": "HashiCorp Vault Lookup token",
